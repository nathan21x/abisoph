{
    "version": 2,
    "builds": [
        {
            "src": "api/server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/server.js"
        }
    ],
    "cron": [
    {
      "path": "/api/cron",
      "schedule": "*/1 * * * *"
    }
  ]
}